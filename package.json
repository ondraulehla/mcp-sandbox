{
  "name": "mcp-sandbox",
  "version": "0.1.0",
  "description": "Run any MCP server inside an isolated E2B cloud sandbox instead of on your machine — one command, no code changes. Transparent stdio bridge with env allowlisting and JSONL traffic tracing.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sandbox",
    "e2b",
    "security",
    "isolation",
    "ai-agents"
  ],
  "license": "MIT",
  "author": "Ondřej Úlehla",
  "type": "module",
  "bin": {
    "mcp-sandbox": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "e2b": "^2.32.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
